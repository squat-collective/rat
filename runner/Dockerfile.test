# Test image — deps pre-installed, source mounted at runtime.
# Build: docker build -f runner/Dockerfile.test -t rat-runner-test runner/
# Run:   docker run --rm -v $(pwd)/runner/src:/app/src -v $(pwd)/runner/tests:/app/tests rat-runner-test
FROM python:3.14-slim
WORKDIR /app
# build-essential: pyiceberg ships no cp314 wheel yet, so its avro C extension
# is compiled from sdist during `uv sync`. (Test image — not shipped, so it's
# fine to leave the toolchain in this single stage.) Drop once cp314 wheels land.
RUN apt-get update \
  && apt-get install -y --no-install-recommends build-essential \
  && rm -rf /var/lib/apt/lists/*
RUN pip install --no-cache-dir uv
COPY pyproject.toml uv.lock ./
COPY src/ ./src/
# `uv sync --locked` asserts that uv.lock is in sync with pyproject.toml and
# fails the build if the lockfile is stale. (--frozen would silently skip
# resolution; --locked is the correct strict-mode flag.)
RUN uv sync --locked --extra dev
ENV PATH="/app/.venv/bin:$PATH"
CMD ["pytest", "-v"]
